{
  "name": "youtube-downloader",
  "version": "1.3.0",
  "description": "Clean and fast YouTube Downloader (and 1000+ sites)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish never"
  },
  "build": {
    "appId": "com.yourname.youtubedownloader",
    "productName": "YouTube Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/yt-dlp-exec/bin/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "electron": "^34.0.0",
    "yt-dlp-exec": "^2.5.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  }
}
